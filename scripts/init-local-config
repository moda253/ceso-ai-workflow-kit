#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONFIG="$ROOT/config.local.json"

if [ -f "$CONFIG" ]; then
  echo "config.local.json already exists."
  exit 0
fi

cp "$ROOT/config.example.json" "$CONFIG"
echo "Created config.local.json from config.example.json."
echo "Edit config.local.json to choose which Claude files and skills to sync."
