#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

mkdir -p "$ROOT/codex/generated"
mkdir -p "$ROOT/codex/skills"
mkdir -p "$ROOT/codex/projects"

cat > "$ROOT/codex/generated/CLAUDE.md" <<'HEADER'
<!-- GENERATED FROM claude/CLAUDE.md. Do not edit directly. -->

HEADER

cat "$ROOT/claude/CLAUDE.md" >> "$ROOT/codex/generated/CLAUDE.md"

if [ -d "$ROOT/claude/skills" ]; then
  find "$ROOT/claude/skills" -mindepth 1 -maxdepth 1 -type d | while read -r skill_dir; do
    skill_name="$(basename "$skill_dir")"
    target_dir="$ROOT/codex/skills/$skill_name"

    rm -rf "$target_dir"
    mkdir -p "$target_dir"
    cp -R "$skill_dir"/. "$target_dir"/

    if [ -f "$target_dir/SKILL.md" ]; then
      tmp_file="$(mktemp)"
      {
        echo "<!-- GENERATED FROM claude/skills/$skill_name. Do not edit directly. -->"
        echo
        cat "$target_dir/SKILL.md"
      } > "$tmp_file"
      mv "$tmp_file" "$target_dir/SKILL.md"
    fi
  done
fi

if [ -d "$ROOT/claude/projects" ]; then
  rm -rf "$ROOT/codex/projects"
  mkdir -p "$ROOT/codex/projects"
  cp -R "$ROOT/claude/projects"/. "$ROOT/codex/projects"/

  find "$ROOT/codex/projects" -name "CLAUDE.md" -type f | while read -r project_file; do
    relative_path="${project_file#$ROOT/codex/projects/}"
    tmp_file="$(mktemp)"
    {
      echo "<!-- GENERATED FROM claude/projects/$relative_path. Do not edit directly. -->"
      echo
      cat "$project_file"
    } > "$tmp_file"
    mv "$tmp_file" "$project_file"
  done
fi

echo "Synced Claude workflow into Codex generated output."
