#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"

mkdir -p "$CODEX_HOME/generated"
mkdir -p "$CODEX_HOME/skills"
mkdir -p "$CODEX_HOME/projects"

cp "$ROOT/codex/generated/CLAUDE.md" "$CODEX_HOME/generated/CLAUDE.md"

if [ -d "$ROOT/codex/skills" ]; then
  find "$ROOT/codex/skills" -mindepth 1 -maxdepth 1 -type d | while read -r skill_dir; do
    skill_name="$(basename "$skill_dir")"
    target_dir="$CODEX_HOME/skills/$skill_name"

    rm -rf "$target_dir"
    mkdir -p "$target_dir"
    cp -R "$skill_dir"/. "$target_dir"/
  done
fi

if [ -d "$ROOT/codex/projects" ]; then
  rm -rf "$CODEX_HOME/projects"
  mkdir -p "$CODEX_HOME/projects"
  cp -R "$ROOT/codex/projects"/. "$CODEX_HOME/projects"/
fi

echo "Installed Codex workflow into $CODEX_HOME."
